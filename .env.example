# Copy to .env and adjust. The API and extractor read DATABASE_URL.
# Local dev (peer auth over unix socket, role = OS user tkadmin):
DATABASE_URL=postgresql:///wp_tt

# The extractor (and ONLY the extractor) also needs the Oracle toolbox skill:
SKILL_DIR=/home/aiadmin/.codex/skills/yard-db-ops

# API bind address (optional):
API_ADDR=127.0.0.1:8080
